[global]
    ### Posizionamento e Monitor ###
    monitor = 0
    follow = keyboard
    width = (300, 600)
    origin = top-right
    offset = (50, 45)
    scale = 1
    indicate_hidden = yes
    shrink = no

    ### Grafica, Bordi e Angoli ###
    transparency = 5
    separator_height = 5
    padding = 12
    horizontal_padding = 8
    frame_width = 2
    frame_color = "#282c34"
    separator_color = frame
    corner_radius = 10
    sort = yes
    idle_threshold = 120

    ### Carattere e Testo ###
    font = Noto Sans 11
    line_height = 0
    markup = full

    # Formato: Nome App in grigio piccolo, Titolo in grassetto, Corpo della notifica
    format = "<span size='small' foreground='#888888'>%a</span>\n<b>%s</b>\n%b"
    
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### CONFIGURAZIONE ICONE CON TEMA PAPIRUS ###
    # Posiziona l'icona grafica a sinistra del testo
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    
    # INDISPENSABILE: Abilita Dunst a cercare nelle sottocartelle del tema (es. 48x48/apps, scalable, ecc.)
    enable_recursive_icon_lookup = true
    
    # Specifica il tema principale e le sue varianti/fallback separati da virgola
    icon_theme = "Papirus-Dark,Papirus,Adwaita"
    
    # Percorsi di fallback diretti nel caso in cui i canali D-Bus standard falliscano la ricerca
    icon_path = /usr/share/icons/Papirus-Dark/48x48/apps/:/usr/share/icons/Papirus/48x48/apps/:/usr/share/icons/Adwaita/32x32/apps/

    ### Interazioni e Comandi ###
    sticky_history = yes
    history_length = 20
    dmenu = rofi -dmenu -p dunst
    browser = brave
    always_run_script = true
    title = Dunst
    class = Dunst

[experimental]
    per_monitor_dpi = true

[mouse]
    mouse_left_click = do_action

[urgency_low]
    background = "#24272e"
    foreground = "#abb2bf"
    timeout = 7

[urgency_normal]
    background = "#24272e"
    foreground = "#abb2bf"
    timeout = 7

[urgency_critical]
    background = "#24272e"
    foreground = "#abb2bf"
    frame_color = "#e06c75"
    timeout = 0

[Spotify]
    appname = Spotify
    new_icon = /home/gabry/.local/share/icons/hicolor/64x64/apps/spotify.png
    timeout = 3